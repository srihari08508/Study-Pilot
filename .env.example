# LLM provider for CrewAI agents (crewai uses litellm under the hood —
# set whichever provider key you're using; OpenAI shown as default)
OPENAI_API_KEY=your-openai-key-here
# OPENAI_MODEL_NAME=gpt-4o-mini

# Live web search for the Recommender agent (https://tavily.com — free tier)
TAVILY_API_KEY=your-tavily-key-here

# Optional: external MCP servers for the Recommender agent to consume,
# as a JSON list. Leave blank to skip.
# MCP_SERVERS=[{"url": "http://localhost:9000/sse"}]

# Where planner state is persisted (shared by backend + MCP server)
STUDYPILOT_DATA_FILE=study_data.json

# Autonomous background loop (core/automation.py) — runs with NO user
# interaction: periodically re-checks the plan, and if it finds overdue
# or at-risk topics, automatically dispatches the full 4-agent crew.
AUTO_DAILY_HOURS=3
AUTO_CHECK_INTERVAL_MINUTES=60
